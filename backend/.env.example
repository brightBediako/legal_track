NODE_ENV=development

# PostgreSQL database connection
# Use a fully expanded URL — Prisma does not expand ${DB_USERNAME} style placeholders.
# Create the database first, then apply migrations (see context/library-docs.md):
#   npm run db:migrate
#
# Local example:
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/legaltrack?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/legaltrack?schema=public

# Optional discrete fields (for your own scripts; not read by Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=legaltrack

# JWT configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_SECURE=true

# AWS S3 configuration
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=your-region
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
