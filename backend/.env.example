NODE_ENV=development

# PostgreSQL database connection
# Use a fully expanded URL — Prisma does not expand ${DB_USERNAME} style placeholders.
# Create the database first, then apply migrations (see context/library-docs.md):
#   npm run db:migrate
#
# Local example:
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/legaltrack?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/legaltrack?schema=public

# Optional discrete fields (for your own scripts; not read by Prisma)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=legaltrack

# Bootstrap admin (created on API boot + `npm run db:seed:admin`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
# Set true once to reset the admin password from env (then set back to false)
ADMIN_FORCE_RESET=false

# JWT configuration
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600s
# Refresh token lifetime in days (opaque token stored hashed in DB)
JWT_REFRESH_DAYS=7

# Comma-separated frontend origins for CORS (required for production)
# Example: https://legaltrack-app.onrender.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Rate limiting (@nestjs/throttler). TTL is milliseconds.
# Set THROTTLE_DISABLED=true for local integration scripts if needed.
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=10
THROTTLE_UPLOAD_LIMIT=20
# THROTTLE_DISABLED=false

# Cloudinary configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_SECURE=true

# AWS S3 configuration
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=your-region
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional override for smoke tests
# API_BASE_URL=http://localhost:4000
