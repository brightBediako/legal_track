    "db:generate": "npm run db:generate --workspace @legal-track/backend",
    "db:migrate": "npm run db:migrate --workspace @legal-track/backend",
    "db:migrate:dev": "npm run db:migrate:dev --workspace @legal-track/backend",
    "db:migrate:status": "npm run db:migrate:status --workspace @legal-track/backend",
